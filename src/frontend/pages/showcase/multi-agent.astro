---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { MultiAgentPanel } from "@/components/showcase/MultiAgentPanel";
---

<BaseLayout
  title="Multi-Agent"
  description="An orchestrator that delegates tasks to researcher and coder subagents"
>
  <div class="container mx-auto max-w-7xl px-4 py-12">
    <header class="mb-8">
      <div class="mb-3 flex items-center gap-3">
        <h1 class="text-3xl font-bold tracking-tight">Multi-Agent</h1>
        <Badge variant="outline">orchestrator-agent</Badge>
      </div>
      <p class="max-w-2xl text-sm text-muted-foreground">
        The orchestrator is an RPC agent that routes work to specialised
        subagents. Send a task and it calls
        <code class="text-primary">delegate("research" | "code", task)</code>; the
        result panel shows exactly which subagent instance ran, its real output,
        and how long it took. <code class="text-primary">getStats()</code> tracks the
        running delegation totals.
      </p>
    </header>

    <MultiAgentPanel client:only="react" />
  </div>
</BaseLayout>
