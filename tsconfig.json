{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["@cloudflare/workers-types"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": ["src/frontend/*", "src/backend/*"]
    }
  },
  "include": [".astro/types.d.ts", "src/**/*", "worker-configuration.d.ts"]
}
